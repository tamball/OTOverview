{
  "bookId": "habakkuk",
  "note": "修訂版中文譯本（RCUV），由 RCUV/*.rtf 經 textutil + import_bible_text.py 匯入；請遵守版權與使用條款。",
  "chapters": {
    "1": [
      {
        "v": 1,
        "t": "哈巴谷先知所看見的默示。"
      },
      {
        "v": 2,
        "t": "耶和華啊，我呼求，"
      },
      {
        "v": 3,
        "t": "你為何使我看見罪孽？"
      },
      {
        "v": 4,
        "t": "因此律法無效，"
      },
      {
        "v": 5,
        "t": "你們要向列國觀看1，注意看，"
      },
      {
        "v": 6,
        "t": "看哪，我必興起迦勒底人，"
      },
      {
        "v": 7,
        "t": "他威武可畏，"
      },
      {
        "v": 8,
        "t": "他的馬比豹更快，"
      },
      {
        "v": 9,
        "t": "都為施行殘暴而來，"
      },
      {
        "v": 10,
        "t": "他譏誚列王，"
      },
      {
        "v": 11,
        "t": "那時，他如風猛然掃過，"
      },
      {
        "v": 12,
        "t": "耶和華－我的上帝，我的聖者啊，"
      },
      {
        "v": 13,
        "t": "你的眼目清潔，"
      },
      {
        "v": 14,
        "t": "你為何使人如海中的魚，"
      },
      {
        "v": 15,
        "t": "他用鉤子把他們全拉上來，"
      },
      {
        "v": 16,
        "t": "向羅網獻祭，"
      },
      {
        "v": 17,
        "t": "但他豈可因此屢屢倒空羅網，"
      }
    ],
    "2": [
      {
        "v": 1,
        "t": "我要站在我的瞭望臺，"
      },
      {
        "v": 2,
        "t": "耶和華回答我，說："
      },
      {
        "v": 3,
        "t": "因為這默示有一定日期，"
      },
      {
        "v": 4,
        "t": "看哪，惡人自高自大，心不正直；"
      },
      {
        "v": 5,
        "t": "他因酒詭詐、"
      },
      {
        "v": 6,
        "t": "這些人豈不都要提起詩歌和俗語，嘲諷他說："
      },
      {
        "v": 7,
        "t": "咬傷你的豈不忽然興起，"
      },
      {
        "v": 8,
        "t": "因你搶奪許多國家，"
      },
      {
        "v": 9,
        "t": "禍哉！那為本家積蓄不義之財、"
      },
      {
        "v": 10,
        "t": "你圖謀剪除許多民族，犯了罪，"
      },
      {
        "v": 11,
        "t": "牆裏的石頭要呼叫，"
      },
      {
        "v": 12,
        "t": "禍哉！那以鮮血建城、"
      },
      {
        "v": 13,
        "t": "看哪，這不都是出於萬軍之耶和華嗎？"
      },
      {
        "v": 14,
        "t": "全地都必認識耶和華的榮耀，"
      },
      {
        "v": 15,
        "t": "禍哉！那給鄰舍酒喝，加上毒物，"
      },
      {
        "v": 16,
        "t": "你滿受羞辱，不得榮耀；"
      },
      {
        "v": 17,
        "t": "黎巴嫩所受的殘暴必淹沒你，"
      },
      {
        "v": 18,
        "t": "偶像有甚麼益處呢？"
      },
      {
        "v": 19,
        "t": "禍哉！那對木頭說「醒起」，"
      },
      {
        "v": 20,
        "t": "惟耶和華在他的聖殿中，"
      }
    ],
    "3": [
      {
        "v": 1,
        "t": "哈巴谷先知的禱告，調用流離歌。"
      },
      {
        "v": 2,
        "t": "耶和華啊，我聽見你的名聲；"
      },
      {
        "v": 3,
        "t": "上帝從提幔而來，"
      },
      {
        "v": 4,
        "t": "他的輝煌如同日光，"
      },
      {
        "v": 5,
        "t": "在他前面有瘟疫流行，"
      },
      {
        "v": 6,
        "t": "他站立，震動大地，"
      },
      {
        "v": 7,
        "t": "我見古珊的帳棚遭難，"
      },
      {
        "v": 8,
        "t": "耶和華啊，你豈是向江河發怒，"
      },
      {
        "v": 9,
        "t": "你的弓全然顯露，"
      },
      {
        "v": 10,
        "t": "山嶺見你，無不戰抖；"
      },
      {
        "v": 11,
        "t": "因你的箭射出光芒，"
      },
      {
        "v": 12,
        "t": "你發怒遍行大地，"
      },
      {
        "v": 13,
        "t": "你出來拯救你的百姓，"
      },
      {
        "v": 14,
        "t": "你以其戈矛刺透他戰士的頭；"
      },
      {
        "v": 15,
        "t": "你騎馬踐踏海，"
      },
      {
        "v": 16,
        "t": "我聽見這聲音，身體戰兢，"
      },
      {
        "v": 17,
        "t": "雖然無花果樹不發旺，"
      },
      {
        "v": 18,
        "t": "然而，我要因耶和華歡欣，"
      },
      {
        "v": 19,
        "t": "主耶和華是我的力量，"
      }
    ]
  }
}
