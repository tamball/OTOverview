{
  "bookId": "zephaniah",
  "note": "修訂版中文譯本（RCUV），由 RCUV/*.rtf 經 textutil + import_bible_text.py 匯入；請遵守版權與使用條款。",
  "chapters": {
    "1": [
      {
        "v": 1,
        "t": "當亞們的兒子猶大王約西亞在位的時候，耶和華的話臨到希西家的玄孫，亞瑪利雅的曾孫，基大利的孫子，古示的兒子西番雅。"
      },
      {
        "v": 2,
        "t": "耶和華說："
      },
      {
        "v": 3,
        "t": "我必除滅人與牲畜，"
      },
      {
        "v": 4,
        "t": "我必伸手攻擊猶大"
      },
      {
        "v": 5,
        "t": "還有那些在屋頂拜天上萬象的，"
      },
      {
        "v": 6,
        "t": "並那些轉去不跟從耶和華，"
      },
      {
        "v": 7,
        "t": "在主耶和華面前要靜默無聲，"
      },
      {
        "v": 8,
        "t": "「到了獻祭給耶和華的日子，"
      },
      {
        "v": 9,
        "t": "到那日，我必懲罰所有跳過門檻，"
      },
      {
        "v": 10,
        "t": "「當那日，從魚門必發出悲哀的聲音，"
      },
      {
        "v": 11,
        "t": "瑪革提施的居民哪，你們要哀號，"
      },
      {
        "v": 12,
        "t": "那時，我必用燈巡查耶路撒冷，"
      },
      {
        "v": 13,
        "t": "他們的財寶成為掠物，"
      },
      {
        "v": 14,
        "t": "耶和華的大日臨近，"
      },
      {
        "v": 15,
        "t": "那日是憤怒的日子，"
      },
      {
        "v": 16,
        "t": "是吹角吶喊的日子，"
      },
      {
        "v": 17,
        "t": "我必使災禍臨到人身上，"
      },
      {
        "v": 18,
        "t": "當耶和華發怒的日子，"
      }
    ],
    "2": [
      {
        "v": 3,
        "t": "世上遵守耶和華典章的謙卑人哪，"
      },
      {
        "v": 4,
        "t": "迦薩必遭遺棄1，"
      },
      {
        "v": 5,
        "t": "禍哉，住沿海之地的基利提人！"
      },
      {
        "v": 6,
        "t": "沿海之地要變為草場，"
      },
      {
        "v": 7,
        "t": "這地必為猶大家的餘民所得；"
      },
      {
        "v": 8,
        "t": "我聽見摩押毀謗，亞捫人辱罵；"
      },
      {
        "v": 9,
        "t": "萬軍之耶和華－以色列的上帝說："
      },
      {
        "v": 10,
        "t": "這事臨到他們是因他們的驕傲，"
      },
      {
        "v": 11,
        "t": "耶和華必向他們顯為可畏，"
      },
      {
        "v": 12,
        "t": "你們古實人，"
      },
      {
        "v": 13,
        "t": "耶和華要伸手攻擊北方，"
      },
      {
        "v": 14,
        "t": "群畜，就是各類的走獸必臥在其中，"
      },
      {
        "v": 15,
        "t": "這素來歡樂、安然居住的城，"
      }
    ],
    "3": [
      {
        "v": 1,
        "t": "禍哉，這欺壓的城！"
      },
      {
        "v": 2,
        "t": "不聽從命令，"
      },
      {
        "v": 3,
        "t": "其中的領袖是咆哮的獅子，"
      },
      {
        "v": 4,
        "t": "它的先知是虛浮詭詐的人，"
      },
      {
        "v": 5,
        "t": "耶和華在它中間行公義，"
      },
      {
        "v": 6,
        "t": "「我已經除滅列國，"
      },
      {
        "v": 7,
        "t": "我說：『只要你敬畏我，"
      },
      {
        "v": 8,
        "t": "「你們要等候我，"
      },
      {
        "v": 9,
        "t": "「那時，我要改變萬民，"
      },
      {
        "v": 10,
        "t": "那些向我祈求的，"
      },
      {
        "v": 11,
        "t": "「當那日，你必不再因一切得罪我的事蒙羞，"
      },
      {
        "v": 12,
        "t": "我卻要在你中間留下困苦貧寒的百姓，"
      },
      {
        "v": 13,
        "t": "以色列的餘民必不行惡，"
      },
      {
        "v": 14,
        "t": "錫安哪，應當歌唱！"
      },
      {
        "v": 15,
        "t": "耶和華已經免去對你的審判，"
      },
      {
        "v": 16,
        "t": "當那日，必有話對耶路撒冷說："
      },
      {
        "v": 17,
        "t": "耶和華－你的上帝在你中間"
      },
      {
        "v": 18,
        "t": "我要聚集那些因無節期而愁煩的人，"
      },
      {
        "v": 19,
        "t": "那時，看哪，我必對付所有苦待你的人，"
      },
      {
        "v": 20,
        "t": "那時，我必領你們回來，召集你們；"
      }
    ]
  }
}
