  "chapters": {
    "2": [
      {
        "v": 1,
        "t": "那打碎你的人1上到你面前。"
      },
      {
        "v": 2,
        "t": "耶和華復興雅各的榮華，"
      },
      {
        "v": 3,
        "t": "他勇士的盾牌是紅的，"
      },
      {
        "v": 4,
        "t": "戰車在街上疾行，"
      },
      {
        "v": 5,
        "t": "他招聚他的貴族；"
      },
      {
        "v": 6,
        "t": "河閘開放，"
      },
      {
        "v": 7,
        "t": "這是命定之事："
      },
      {
        "v": 8,
        "t": "1尼尼微自古以來"
      },
      {
        "v": 9,
        "t": "你們搶奪金子吧！"
      },
      {
        "v": 10,
        "t": "荒蕪，荒涼，全然荒廢，"
      },
      {
        "v": 11,
        "t": "獅子的洞，"
      },
      {
        "v": 12,
        "t": "公獅撕碎的足夠給幼獅吃，"
      },
      {
        "v": 13,
        "t": "看哪，我與你為敵，將它的戰車焚燒成煙，刀劍必吞滅你的少壯獅子；我必從地上除滅你的獵物，你使者的聲音必不再聽見。這是萬軍之耶和華說的。"
      }
    ],
    "3": [
      {
        "v": 1,
        "t": "禍哉！這流人血的城，"
      },
      {
        "v": 2,
        "t": "鞭聲響亮，車輪轟轟，"
      },
      {
        "v": 3,
        "t": "騎兵爭先，刀劍發光，"
      },
      {
        "v": 4,
        "t": "都因那美貌的妓女多有淫行，"
      },
      {
        "v": 5,
        "t": "看哪，我與你為敵，"
      },
      {
        "v": 6,
        "t": "我必將可憎污穢之物拋在你身上，"
      },
      {
        "v": 7,
        "t": "凡看見你的，都必逃離你，說："
      },
      {
        "v": 8,
        "t": "你能勝過挪亞們嗎？"
      },
      {
        "v": 9,
        "t": "古實和埃及是它的力量，"
      },
      {
        "v": 10,
        "t": "但它被流放，被人擄去，"
      },
      {
        "v": 11,
        "t": "你也必喝醉，昏迷錯亂，"
      },
      {
        "v": 12,
        "t": "你一切的堡壘必如無花果樹上初熟的果子，"
      },
      {
        "v": 13,
        "t": "看哪，你中間的士兵是婦女，"
      },
      {
        "v": 14,
        "t": "你要打水預備受困；"
      },
      {
        "v": 15,
        "t": "在那裏，火要吞滅你，"
      },
      {
        "v": 16,
        "t": "你增添商賈，多過天上的星宿；"
      },
      {
        "v": 17,
        "t": "你的領袖多如蝗蟲，"
      },
      {
        "v": 18,
        "t": "亞述王啊，"
      },
      {
        "v": 19,
        "t": "你的損傷並未減輕，"
      }
    ],
    "11": [
      {
        "v": 1,
        "t": "論尼尼微的默示，伊勒歌斯人那鴻所見異象的書。"
      },
      {
        "v": 2,
        "t": "耶和華是忌邪、報應的上帝。"
      },
      {
        "v": 3,
        "t": "耶和華不輕易發怒，大有能力，"
      },
      {
        "v": 4,
        "t": "他斥責海，使海枯乾，"
      },
      {
        "v": 5,
        "t": "大山因他震動，"
      },
      {
        "v": 6,
        "t": "他發憤恨，誰能立得住呢？"
      },
      {
        "v": 7,
        "t": "耶和華本為善，"
      },
      {
        "v": 8,
        "t": "但他必以漲溢的洪水淹沒其地方，"
      },
      {
        "v": 9,
        "t": "你們籌劃何種計謀攻擊耶和華呢？"
      },
      {
        "v": 10,
        "t": "你們像雜亂的荊棘，"
      },
      {
        "v": 11,
        "t": "有一人從你那裏出來，"
      },
      {
        "v": 12,
        "t": "耶和華如此說："
      },
      {
        "v": 13,
        "t": "現在，我要從你身上折斷他的軛，"
      },
      {
        "v": 14,
        "t": "耶和華已經發命令，指著你說："
      },
      {
        "v": 15,
        "t": "看哪，山上有報佳音、傳平安之人的腳蹤。"
      }
    ]
  }
}
