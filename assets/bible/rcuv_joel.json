  "chapters": {
    "1": [
      {
        "v": 1,
        "t": "耶和華的話臨到毗土珥的兒子約珥。"
      },
      {
        "v": 2,
        "t": "老年人哪，當聽這話；"
      },
      {
        "v": 3,
        "t": "你們要將這事傳與子，"
      },
      {
        "v": 4,
        "t": "剪蟲吃剩的，蝗蟲來吃；"
      },
      {
        "v": 5,
        "t": "醉酒的人哪，要清醒，要哭泣；"
      },
      {
        "v": 6,
        "t": "有一隊蝗蟲，強盛且不可數，"
      },
      {
        "v": 7,
        "t": "牠毀壞我的葡萄樹，"
      },
      {
        "v": 8,
        "t": "你要像童女腰束麻布，"
      },
      {
        "v": 9,
        "t": "耶和華的殿中斷絕素祭和澆酒祭，"
      },
      {
        "v": 10,
        "t": "田荒涼，地悲哀；"
      },
      {
        "v": 11,
        "t": "農夫啊，你們要慚愧；"
      },
      {
        "v": 12,
        "t": "葡萄樹枯乾，"
      },
      {
        "v": 13,
        "t": "祭司啊，當束上麻布痛哭；"
      },
      {
        "v": 14,
        "t": "你們要使禁食的日子分別為聖，"
      },
      {
        "v": 15,
        "t": "哀哉，這日子！"
      },
      {
        "v": 16,
        "t": "糧食不是在我們眼前斷絕了嗎？"
      },
      {
        "v": 17,
        "t": "種子在土塊下朽爛，"
      },
      {
        "v": 18,
        "t": "牲畜哀鳴，"
      },
      {
        "v": 19,
        "t": "耶和華啊，我向你求告，"
      },
      {
        "v": 20,
        "t": "田野的走獸切慕你，"
      }
    ],
    "2": [
      {
        "v": 1,
        "t": "你們要在錫安吹角，"
      },
      {
        "v": 2,
        "t": "那是黑暗、陰森的日子，"
      },
      {
        "v": 3,
        "t": "牠們前面有火吞噬，"
      },
      {
        "v": 4,
        "t": "牠們形狀如馬，"
      },
      {
        "v": 5,
        "t": "響聲如戰車在山頂上跳動，"
      },
      {
        "v": 6,
        "t": "在牠們面前，萬民傷慟，"
      },
      {
        "v": 7,
        "t": "牠們如勇士奔跑，"
      },
      {
        "v": 8,
        "t": "牠們並不彼此推擠，"
      },
      {
        "v": 9,
        "t": "牠們蹦上城，"
      },
      {
        "v": 10,
        "t": "在牠們面前，"
      },
      {
        "v": 11,
        "t": "耶和華在他的軍旅前出聲，"
      },
      {
        "v": 12,
        "t": "然而你們現在要禁食，哭泣，哀號，"
      },
      {
        "v": 13,
        "t": "你們要撕裂心腸，"
      },
      {
        "v": 14,
        "t": "誰知道他也許會回心轉意，留下餘福，"
      },
      {
        "v": 15,
        "t": "你們要在錫安吹角，"
      },
      {
        "v": 16,
        "t": "聚集百姓，使會眾自潔；"
      },
      {
        "v": 17,
        "t": "事奉耶和華的祭司"
      },
      {
        "v": 18,
        "t": "耶和華為自己的地發熱心，"
      },
      {
        "v": 19,
        "t": "耶和華應允他的百姓說："
      },
      {
        "v": 20,
        "t": "我要使北方來的隊伍遠離你們，"
      },
      {
        "v": 21,
        "t": "「土地啊，不要懼怕，"
      },
      {
        "v": 22,
        "t": "田野的走獸啊，不要懼怕，"
      },
      {
        "v": 23,
        "t": "「錫安的民哪，你們要歡喜，"
      },
      {
        "v": 24,
        "t": "「禾場充滿五穀，"
      },
      {
        "v": 25,
        "t": "我差遣到你們中間的大軍隊，"
      },
      {
        "v": 26,
        "t": "「你們必吃得飽足，"
      },
      {
        "v": 27,
        "t": "你們必知道我是在以色列中，"
      },
      {
        "v": 28,
        "t": "「以後，我要將我的靈澆灌凡有血肉之軀的。"
      },
      {
        "v": 29,
        "t": "在那些日子，"
      },
      {
        "v": 30,
        "t": "「我要在天上地下顯出奇事，有血，有火，有煙柱。"
      },
      {
        "v": 31,
        "t": "太陽要變為黑暗，月亮要變為血，這都在耶和華大而可畏的日子未到以前。"
      },
      {
        "v": 32,
        "t": "那時，凡求告耶和華名的就必得救；因為照耶和華所說的，在錫安山，在耶路撒冷將有逃脫的人。凡耶和華所召的，都在餘民之列。」"
      }
    ],
    "3": [
      {
        "v": 1,
        "t": "「看哪，在那些日子，到那個時候，我使猶大和耶路撒冷被擄之人歸回的時候，"
      },
      {
        "v": 2,
        "t": "我要聚集萬民，帶他們下到約沙法谷去，在那裏我要為我百姓，我產業以色列的緣故，向萬民施行審判；因為他們把我的百姓分散到列國，瓜分了我的土地，"
      },
      {
        "v": 3,
        "t": "為我的百姓抽籤，以男孩換取妓女，為喝酒賣掉女孩。"
      },
      {
        "v": 4,
        "t": "「推羅、西頓和非利士四境的人哪，你們與我何干？你們要報復我嗎？若要報復我，我必使報應速速歸到你們頭上。"
      },
      {
        "v": 5,
        "t": "你們奪取我的金銀，把我珍貴的寶物帶入你們的廟宇1，"
      },
      {
        "v": 6,
        "t": "並將猶大人和耶路撒冷人賣給希臘人，使他們遠離自己的疆土。"
      },
      {
        "v": 7,
        "t": "看哪，我必激發他們離開你們把他們賣去的地方，又必使報應歸到你們頭上。"
      },
      {
        "v": 8,
        "t": "我要將你們的兒女賣到猶大人手中，他們必轉賣給遠方的國家示巴人。這是耶和華說的。」"
      },
      {
        "v": 9,
        "t": "當在列國中宣告："
      },
      {
        "v": 10,
        "t": "要將犁頭打成刀劍，"
      },
      {
        "v": 11,
        "t": "四圍的列國啊，"
      },
      {
        "v": 12,
        "t": "列國都當興起，"
      },
      {
        "v": 13,
        "t": "揮鐮刀吧！因為莊稼熟了；"
      },
      {
        "v": 14,
        "t": "在斷定谷有許多許多的人，"
      },
      {
        "v": 15,
        "t": "日月昏暗，"
      },
      {
        "v": 16,
        "t": "耶和華必從錫安吼叫，"
      },
      {
        "v": 17,
        "t": "你們就知道我是耶和華－你們的上帝，"
      },
      {
        "v": 18,
        "t": "在那日，大山要滴甜酒，"
      },
      {
        "v": 19,
        "t": "埃及必定荒涼，"
      },
      {
        "v": 20,
        "t": "但猶大必存到永遠，"
      },
      {
        "v": 21,
        "t": "我要免除流人血的罪，"
      }
    ]
  }
}
