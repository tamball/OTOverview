{
  "bookId": "obadiah",
  "note": "修訂版中文譯本（RCUV），由 RCUV/*.rtf 經 textutil + import_bible_text.py 匯入；請遵守版權與使用條款。",
  "chapters": {
    "1": [
      {
        "v": 1,
        "t": "俄巴底亞所見的異象。"
      },
      {
        "v": 2,
        "t": "看哪，我要使你在列國中為最小，"
      },
      {
        "v": 3,
        "t": "你狂傲的心欺騙了你，"
      },
      {
        "v": 4,
        "t": "你雖如鷹高飛，"
      },
      {
        "v": 5,
        "t": "盜賊若來到你那裏，"
      },
      {
        "v": 6,
        "t": "以掃遭到搜查，"
      },
      {
        "v": 7,
        "t": "與你結盟的都驅趕你，直到邊界，"
      },
      {
        "v": 8,
        "t": "到那日，"
      },
      {
        "v": 9,
        "t": "提幔哪，"
      },
      {
        "v": 10,
        "t": "因你向兄弟雅各施暴，"
      },
      {
        "v": 11,
        "t": "當陌生人擄掠雅各的財物，"
      },
      {
        "v": 12,
        "t": "你兄弟遭難的日子，"
      },
      {
        "v": 13,
        "t": "我子民遭災的日子，"
      },
      {
        "v": 14,
        "t": "他們遭難的日子，"
      },
      {
        "v": 15,
        "t": "耶和華的日子臨近萬國；"
      },
      {
        "v": 16,
        "t": "你們在我聖山怎樣喝了苦杯，"
      },
      {
        "v": 17,
        "t": "但在錫安山必有逃脫的人，"
      },
      {
        "v": 18,
        "t": "雅各家必成為大火，"
      },
      {
        "v": 19,
        "t": "他們必得尼革夫和以掃山，"
      },
      {
        "v": 20,
        "t": "被擄的以色列大軍"
      },
      {
        "v": 21,
        "t": "必有一些解救者上到錫安山，審判以掃山，"
      }
    ]
  }
}
