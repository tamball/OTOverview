  "chapters": {
    "1": [
      {
        "v": 1,
        "t": "唉！先前人口稠密的城市，"
      },
      {
        "v": 2,
        "t": "她夜間痛哭，淚流滿頰，"
      },
      {
        "v": 3,
        "t": "猶大被擄，"
      },
      {
        "v": 4,
        "t": "錫安的道路因無人前來過節就哀傷，"
      },
      {
        "v": 5,
        "t": "她的敵人作主，"
      },
      {
        "v": 6,
        "t": "錫安的威榮全都失去。"
      },
      {
        "v": 7,
        "t": "耶路撒冷在困苦窘迫之時，"
      },
      {
        "v": 8,
        "t": "耶路撒冷犯了大罪，"
      },
      {
        "v": 9,
        "t": "她的污穢是在下襬上；"
      },
      {
        "v": 10,
        "t": "敵人伸手奪取她的一切貴重物品；"
      },
      {
        "v": 11,
        "t": "她的百姓都嘆息，尋求食物；"
      },
      {
        "v": 12,
        "t": "所有過路的人哪，願這事不要發生在你們身上。"
      },
      {
        "v": 13,
        "t": "他從高處降火進入我的骨頭，"
      },
      {
        "v": 14,
        "t": "他用手綁我罪過的軛，"
      },
      {
        "v": 15,
        "t": "主棄絕我們當中所有的勇士，"
      },
      {
        "v": 16,
        "t": "我因這些事哭泣，"
      },
      {
        "v": 17,
        "t": "錫安伸出雙手，卻無人安慰。"
      },
      {
        "v": 18,
        "t": "耶和華是公義的！"
      },
      {
        "v": 19,
        "t": "我招呼我所親愛的，"
      },
      {
        "v": 20,
        "t": "耶和華啊，求你觀看，"
      },
      {
        "v": 21,
        "t": "有人聽見我嘆息，"
      },
      {
        "v": 22,
        "t": "願他們的惡行都呈現在你面前；"
      }
    ],
    "2": [
      {
        "v": 1,
        "t": "唉！主竟發怒，使黑雲遮蔽錫安1！"
      },
      {
        "v": 2,
        "t": "主吞滅雅各一切的住處，並不顧惜。"
